<!--
  SIEM Rules — mini-1984
  Place in your SIEM rules directory
-->

<group name="mini_1984,">

  <!-- Screenshot on sensitive site -->
  <rule id="100800" level="10">
    <decoded_as>json</decoded_as>
    <field name="event_type">screenshot_on_sensitive_site</field>
    <description>Screenshot detected while sensitive site was open — user: $(user), host: $(hostname)</description>
    <group>data_protection,insider_threat,</group>
    <mitre>
      <id>T1113</id>
    </mitre>
  </rule>

  <!-- Repeated screenshots -->
  <rule id="100801" level="12" frequency="3" timeframe="300">
    <if_matched_sid>100800</if_matched_sid>
    <same_field>user</same_field>
    <description>Repeated screenshot activity on sensitive sites — user: $(user)</description>
    <group>data_protection,insider_threat,</group>
    <mitre>
      <id>T1113</id>
      <id>T1041</id>
    </mitre>
  </rule>

  <!-- Screen recording -->
  <rule id="100802" level="12">
    <if_sid>100800</if_sid>
    <field name="detection_tool">obs|kazam|simplescreenrecorder|peek|screencast-file</field>
    <description>Screen recording tool used while sensitive site open — user: $(user)</description>
    <group>data_protection,insider_threat,</group>
    <mitre>
      <id>T1113</id>
    </mitre>
  </rule>

  <!-- Personal email detected -->
  <rule id="100810" level="8">
    <decoded_as>json</decoded_as>
    <field name="event_type">personal_email_detected</field>
    <description>Personal email login detected on endpoint — user: $(user), host: $(hostname)</description>
    <group>policy_violation,</group>
  </rule>

  <!-- Repeated personal email usage -->
  <rule id="100811" level="10" frequency="5" timeframe="3600">
    <if_matched_sid>100810</if_matched_sid>
    <same_field>user</same_field>
    <description>Repeated personal email usage on endpoint — user: $(user)</description>
    <group>policy_violation,</group>
  </rule>

</group>
